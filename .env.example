# ─────────────────────────────────────────────────────────────
# PythGuard Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Pyth Pro ──────────────────────────────────────────────────
# Get your token by DMing CHOPPAtheSHARK on the Pyth Developer Forum:
# https://dev-forum.pyth.network/t/getting-started-faq/524
PYTH_PRO_ACCESS_TOKEN=nMNHlpbPWlz4XYRgQfqrNPtbzXjRbAB7wVv-hackathon

# Pyth MCP server (no need to change this)
PYTH_MCP_SERVER_URL=https://mcp.pyth.network/mcp

# ── Solana ────────────────────────────────────────────────────
# Use a private RPC for production (Helius, Triton, QuickNode)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Internal services ─────────────────────────────────────────
RUST_READER_ADDR=0.0.0.0:8001
RUST_READER_BASE_URL=http://localhost:8001

# ── Backend API ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Risk thresholds (optional — defaults shown) ───────────────
HIGH_RISK_SCORE_THRESHOLD=75.0
MEDIUM_RISK_SCORE_THRESHOLD=45.0
CONFIDENCE_RATIO_HIGH_RISK_THRESHOLD=0.005
CONFIDENCE_RATIO_MEDIUM_RISK_THRESHOLD=0.001

# ── Frontend ──────────────────────────────────────────────────
VITE_BACKEND_URL=http://localhost:8000

# ── Telegram Alerts ───────────────────────────────────────────
# 1. Create a bot via @BotFather on Telegram → paste token below
# 2. Send /start to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → copy "id" field
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
MONITORED_WALLETS=wallet_address_1,wallet_address_2
ALERT_POLLING_SECONDS=30
